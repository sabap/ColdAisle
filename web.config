<?xml version="1.0" encoding="UTF-8"?>
<!--
  ColdAisle — IIS configuration
  Requires: URL Rewrite module (optional), PHP 8.x via FastCGI, sqlsrv or ODBC
-->
<configuration>
  <system.webServer>
    <defaultDocument>
      <files>
        <clear />
        <add value="index.php" />
        <add value="setup.php" />
      </files>
    </defaultDocument>

    <directoryBrowse enabled="false" />

    <httpErrors errorMode="DetailedLocalOnly" />

    <security>
      <requestFiltering>
        <hiddenSegments>
          <add segment="config" />
          <add segment="sql" />
          <add segment="src" />
          <add segment="storage" />
          <add segment="scripts" />
        </hiddenSegments>
        <fileExtensions>
          <add fileExtension=".sql" allowed="false" />
          <add fileExtension=".log" allowed="false" />
        </fileExtensions>
      </requestFiltering>
    </security>

    <!-- Block direct access to sensitive paths when rewrite is available -->
    <rewrite>
      <rules>
        <!--
          Optional HTTP→HTTPS at IIS layer. Prefer Settings → Security → Force HTTPS
          (app-level) so lab installs over plain HTTP keep working until a cert is bound.
          To enforce at IIS: remove the conditions that disable this rule, or set enabled="true"
          after binding a certificate.
        -->
        <rule name="HTTP to HTTPS" enabled="false" stopProcessing="true">
          <match url="(.*)" />
          <conditions>
            <add input="{HTTPS}" pattern="off" ignoreCase="true" />
          </conditions>
          <action type="Redirect" url="https://{HTTP_HOST}/{R:1}" redirectType="Permanent" />
        </rule>
        <rule name="Block config" stopProcessing="true">
          <match url="^config/" />
          <action type="CustomResponse" statusCode="403" statusReason="Forbidden" statusDescription="Forbidden" />
        </rule>
        <rule name="Block src" stopProcessing="true">
          <match url="^src/" />
          <action type="CustomResponse" statusCode="403" statusReason="Forbidden" statusDescription="Forbidden" />
        </rule>
        <rule name="Block storage" stopProcessing="true">
          <match url="^storage/" />
          <action type="CustomResponse" statusCode="403" statusReason="Forbidden" statusDescription="Forbidden" />
        </rule>
        <rule name="Block sql" stopProcessing="true">
          <match url="^sql/" />
          <action type="CustomResponse" statusCode="403" statusReason="Forbidden" statusDescription="Forbidden" />
        </rule>
      </rules>
    </rewrite>

    <!-- Strip server tech disclosure; security headers are sent by the PHP app (App::sendSecurityHeaders) -->
    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By" />
      </customHeaders>
    </httpProtocol>

    <staticContent>
      <remove fileExtension=".json" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
      <remove fileExtension=".woff2" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
    </staticContent>

    <handlers>
      <!-- Ensure PHP handles .php — adjust if your FastCGI path differs -->
    </handlers>
  </system.webServer>

  <location path="setup.php">
    <system.webServer>
      <!-- Setup is intentionally public until installed -->
    </system.webServer>
  </location>
</configuration>
